<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.NearFieldStep1View"
             x:DataType="vm:NearFieldStep1ViewModel"
             x:CompileBindings="False">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
          RowSpacing="16">
      <Grid ColumnDefinitions="1.35*,*"
            ColumnSpacing="18">
        <Border Background="#F8FAFD"
                BorderBrush="#E1E6EF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Lista kontrolna stanowiska"
                       FontSize="19"
                       FontWeight="SemiBold"/>
            <CheckBox IsChecked="{Binding ProbeConnected}">
              <TextBlock Text="Sonda R&amp;S H 400-1 jest połączona przez wzmacniacz z miernikiem mocy." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding GeneratorConfigured}">
              <TextBlock Text="Generator: sygnał niemodulowany, moc 10 dBm, częstotliwość zgodna z punktem pomiarowym." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding PowerMeterConfigured}">
              <TextBlock Text="Miernik R&amp;S NRP: PRESET i częstotliwość zgodna z generatorem." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding MaximumSearchUnderstood}">
              <TextBlock Text="Sondę przykładam ściśle do kabla, obracam dla maksimum i przesuwam wzdłuż całego kabla." TextWrapping="Wrap"/>
            </CheckBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#FFF8ED"
                BorderBrush="#FED7AA"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="10">
            <TextBlock Text="Aparatura"
                       FontSize="19"
                       FontWeight="SemiBold"/>
            <TextBlock Text="• generator sygnału"/>
            <TextBlock Text="• miernik mocy R&amp;S NRP z sondą"/>
            <TextBlock Text="• sonda H 400-1, zestaw R&amp;S HZ-15"/>
            <TextBlock Text="• wzmacniacz R&amp;S HZ-16, tor 50 Ω"/>
            <TextBlock Text="• płytki PCB: 30 Ω, 50 Ω i 100 Ω"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Background="#F8FAFD"
              BorderBrush="#E1E6EF"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <WrapPanel Orientation="Horizontal">
          <StackPanel Width="190" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="Temperatura [°C]"/>
            <TextBox Text="{Binding TemperatureCelsius}"/>
          </StackPanel>
          <StackPanel Width="190" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="Wilgotność [%]"/>
            <TextBox Text="{Binding HumidityPercent}"/>
          </StackPanel>
          <StackPanel Width="190" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="Ciśnienie [hPa]"/>
            <TextBox Text="{Binding PressureHpa}"/>
          </StackPanel>
        </WrapPanel>
      </Border>

      <Border Grid.Row="2"
              Background="#F1F8FF"
              BorderBrush="#C9DDFC"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <WrapPanel Orientation="Horizontal">
          <StackPanel Width="135" Margin="0,0,12,10" Spacing="5"><TextBlock Text="uP [dB]"/><TextBox Text="{Binding PowerMeterUncertaintyDb}"/></StackPanel>
          <StackPanel Width="135" Margin="0,0,12,10" Spacing="5"><TextBlock Text="uK [dB]"/><TextBox Text="{Binding AmplifierUncertaintyDb}"/></StackPanel>
          <StackPanel Width="135" Margin="0,0,12,10" Spacing="5"><TextBlock Text="uSp [dB]"/><TextBox Text="{Binding ProbeUncertaintyDb}"/></StackPanel>
          <StackPanel Width="135" Margin="0,0,12,10" Spacing="5"><TextBlock Text="uRep [dB]"/><TextBox Text="{Binding RepeatabilityUncertaintyDb}"/></StackPanel>
          <StackPanel Width="135" Margin="0,0,12,10" Spacing="5"><TextBlock Text="k"/><TextBox Text="{Binding CoverageFactor}"/></StackPanel>
        </WrapPanel>
      </Border>

      <Border Grid.Row="3"
              Background="#EEF4FF"
              BorderBrush="#CADBFF"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14">
        <TextBlock Text="Zakres: 100–1000 MHz, krok 100 MHz. Dla każdej częstotliwości wykonaj pomiar kolejno z płytką 30 Ω, 50 Ω i 100 Ω."
                   Foreground="#244A8A"
                   TextWrapping="Wrap"/>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
