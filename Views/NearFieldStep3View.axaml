<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CrosstalkAnalyzer.Controls"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.NearFieldStep3View"
             x:DataType="vm:NearFieldStep3ViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="14">
    <Grid ColumnDefinitions="1.45*,*"
          ColumnSpacing="14">
      <controls:MathFormulaControl Caption="RÓWNANIE PRZETWARZANIA"
                                   Latex="\begin{aligned}H_{\mathrm{dBA/m}}&amp;=P_{\mathrm{dBm}}-30+10\log_{10}(50)-K+S_p\\H_{\mathrm{A/m}}&amp;=10^{\frac{H_{\mathrm{dBA/m}}}{20}}\end{aligned}"
                                   Description="P - wskazanie miernika mocy; K - wzmocnienie toru; Sp - poprawka sondy."
                                   AccessibleText="Poziom pola H uwzględnia wskazanie mocy, impedancję pięćdziesiąt omów, wzmocnienie i poprawkę sondy."/>

      <Border Grid.Column="1"
              Background="#EEF4FF"
              BorderBrush="#CADBFF"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="5">
          <TextBlock Text="BUDŻET NIEPEWNOŚCI"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#315FAD"/>
          <TextBlock Text="{Binding CombinedUncertaintyText, StringFormat='uH = {0} dB'}"
                     FontSize="17"
                     FontWeight="SemiBold"/>
          <TextBlock Text="{Binding ExpandedUncertaintyText, StringFormat='U95 = k·uH = {0} dB'}"
                     FontSize="17"
                     FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
    </Grid>

    <controls:MathFormulaControl Grid.Row="1"
                                 Caption="BUDŻET NIEPEWNOŚCI"
                                 Latex="u_H=\sqrt{u_P^2+u_K^2+u_{S_p}^2+u_{\mathrm{rep}}^2},\qquad U_{95}=k\,u_H"
                                 Description="Składniki standardowe są łączone metodą RSS. Współczynnik rozszerzenia k jest konfigurowany w kroku przygotowania."
                                 AccessibleText="Niepewność standardowa pola jest pierwiastkiem z sumy kwadratów niepewności miernika, wzmocnienia, sondy i powtarzalności."/>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Results}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="f [MHz]" Width="0.65*" Binding="{Binding FrequencyText}"/>
        <DataGridTextColumn Header="K [dB]" Width="0.7*" Binding="{Binding AmplifierGainText}"/>
        <DataGridTextColumn Header="Sp [dB]" Width="0.7*" Binding="{Binding ProbeCorrectionText}"/>
        <DataGridTextColumn Header="H 30 Ω [dBA/m]" Width="1.15*" Binding="{Binding H30OhmText}"/>
        <DataGridTextColumn Header="95% przedział 30 Ω" Width="1.6*" Binding="{Binding H30IntervalText}"/>
        <DataGridTextColumn Header="H 50 Ω [dBA/m]" Width="1.15*" Binding="{Binding H50OhmText}"/>
        <DataGridTextColumn Header="95% przedział 50 Ω" Width="1.6*" Binding="{Binding H50IntervalText}"/>
        <DataGridTextColumn Header="H 100 Ω [dBA/m]" Width="1.15*" Binding="{Binding H100OhmText}"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
