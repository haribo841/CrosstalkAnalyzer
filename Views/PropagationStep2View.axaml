<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.PropagationStep2View"
             x:DataType="vm:PropagationStep2ViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*,Auto"
        RowSpacing="12">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock Text="Tabela 16 punktów pomiarowych"
                   FontSize="20"
                   FontWeight="SemiBold"/>
        <TextBlock Text="Wpisz poziom z analizatora dla polaryzacji poziomej i pionowej. Wartości przykładowe pochodzą z raportu ćwiczenia nr 4."
                   Foreground="#59677C"
                   TextWrapping="Wrap"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Content="Importuj CSV" Classes="secondary" Click="ImportCsv_Click"/>
        <Button Content="Wstaw dane przykładowe"
                Classes="secondary"
                Command="{Binding FillExampleDataCommand}"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Background="#FFF8ED"
            BorderBrush="#FED7AA"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
      <TextBlock Text="W każdym punkcie należy obrócić antenę wokół osi masztu i zapisać maksymalny odczyt dla obu polaryzacji."
                 Foreground="#8A3B12"
                 TextWrapping="Wrap"/>
    </Border>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Measurements}"
              AutoGenerateColumns="False"
              IsReadOnly="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Punkt"
                            Width="0.65*"
                            IsReadOnly="True"
                            Binding="{Binding PointText}"/>
        <DataGridTextColumn Header="Poziom - polaryzacja pozioma"
                            Width="1.3*"
                            Binding="{Binding HorizontalLevelDb, Mode=TwoWay}"/>
        <DataGridTextColumn Header="Poziom - polaryzacja pionowa"
                            Width="1.3*"
                            Binding="{Binding VerticalLevelDb, Mode=TwoWay}"/>
      </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="3" Spacing="4">
      <TextBlock Text="{Binding ImportStatus}" Foreground="#315FAD"/>
      <TextBlock Text="{Binding ValidationMessage}" Foreground="#59677C" FontWeight="SemiBold"/>
    </StackPanel>
  </Grid>
</UserControl>
