<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CrosstalkAnalyzer.Controls"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.RadiatedEmissionStep1View"
             x:DataType="vm:RadiatedEmissionStep1ViewModel"
             x:CompileBindings="False">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto"
          RowSpacing="16">
      <Grid ColumnDefinitions="1.35*,*"
            ColumnSpacing="18">
        <Border Background="#F8FAFD"
                BorderBrush="#E1E6EF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Lista kontrolna scenariusza EN55032"
                       FontSize="19"
                       FontWeight="SemiBold"/>
            <CheckBox IsChecked="{Binding MeasurementDistanceConfirmed}">
              <TextBlock Text="Przyjmuję odległość pomiarową 3 m i zakres 30-1000 MHz." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding HorizontalPolarizationConfirmed}">
              <TextBlock Text="Dla polaryzacji poziomej używam standardowej poprawki AF dipola półfalowego." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding VerticalPolarizationConfirmed}">
              <TextBlock Text="Dla polaryzacji pionowej uwzględniam korektę wynikającą z kąta elewacji anteny." TextWrapping="Wrap"/>
            </CheckBox>
            <CheckBox IsChecked="{Binding UncertaintyBudgetConfirmed}">
              <TextBlock Text="Uwzględniam niepewności: miernik 0,2 dB, AF 0,8 dB, kabel 0,2 dB." TextWrapping="Wrap"/>
            </CheckBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#F1F8FF"
                BorderBrush="#C9DDFC"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="10">
            <controls:MathFormulaControl Caption="ZAŁOŻENIA OBLICZEŃ"
                                         Latex="\begin{aligned}E&amp;=MR+AF+IL\\AF&amp;=20\log_{10}\left(\frac{9{,}73}{\lambda\sqrt{G}}\right),\quad G=1{,}64\end{aligned}"
                                         Description="Limit EN55032 klasy B dla 3 m: 40 dBµV/m w paśmie 30-230 MHz i 47 dBµV/m w paśmie 230-1000 MHz."
                                         AccessibleText="Pole jest sumą wskazania odbiornika, poprawki antenowej i tłumienia kabla."/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Background="#FFF8ED"
              BorderBrush="#FED7AA"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <WrapPanel Orientation="Horizontal">
          <StackPanel Width="170" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="Odległość [m]"/>
            <TextBox Text="{Binding MeasurementDistanceMeters}"/>
          </StackPanel>
          <StackPanel Width="170" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="U(MR) [dB]"/>
            <TextBox Text="{Binding ReceiverUncertaintyDb}"/>
          </StackPanel>
          <StackPanel Width="170" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="U(AF) [dB]"/>
            <TextBox Text="{Binding AntennaFactorUncertaintyDb}"/>
          </StackPanel>
          <StackPanel Width="170" Margin="0,0,12,10" Spacing="5">
            <TextBlock Text="U(IL) [dB]"/>
            <TextBox Text="{Binding CableLossUncertaintyDb}"/>
          </StackPanel>
        </WrapPanel>
      </Border>

      <Border Grid.Row="2"
              Background="#EDF8F1"
              BorderBrush="#BFE3CC"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14">
        <TextBlock Text="W kolejnym kroku wpiszesz surowe wskazania analizatora MR [dBµV], tłumienie kabla IL [dB] i wysokości anteny dla polaryzacji poziomej oraz pionowej."
                   Foreground="#245E3A"
                   TextWrapping="Wrap"/>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
