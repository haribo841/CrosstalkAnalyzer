<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CrosstalkAnalyzer.Controls"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.RadiatedEmissionStep3View"
             x:DataType="vm:RadiatedEmissionStep3ViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="14">
    <Grid ColumnDefinitions="1.45*,*"
          ColumnSpacing="14">
      <controls:MathFormulaControl Caption="RÓWNANIE PRZETWARZANIA"
                                   Latex="\begin{aligned}E_{\mathrm{dB\mu V/m}}&amp;=MR_{\mathrm{dB\mu V}}+AF_{\mathrm{dB/m}}+IL_{\mathrm{dB}}\\AF_{V,\mathrm{corr}}&amp;=AF+\Delta AF(\alpha),\quad \alpha=\arctan\left(\frac{h_V}{d}\right)\end{aligned}"
                                   Description="MR - wskazanie odbiornika; AF - poprawka antenowa; IL - tłumienie kabla; d - odległość pomiarowa."
                                   AccessibleText="Pole elektryczne jest sumą wskazania odbiornika, poprawki antenowej i tłumienia kabla."/>

      <Border Grid.Column="1"
              Background="#EEF4FF"
              BorderBrush="#CADBFF"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="5">
          <TextBlock Text="NIEPEWNOŚĆ 95%"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#315FAD"/>
          <TextBlock Text="{Binding ExpandedUncertaintyText, StringFormat='U_E = {0} dB'}"
                     FontSize="17"
                     FontWeight="SemiBold"/>
          <TextBlock Text="Składniki niepewności są łączone metodą pierwiastka z sumy kwadratów."
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </Grid>

    <controls:MathFormulaControl Grid.Row="1"
                                 Caption="NIEPEWNOŚĆ WYPADKOWA"
                                 Latex="U_E=\sqrt{U_{MR}^2+U_{AF}^2+U_{IL}^2}"
                                 Description="Dla polaryzacji pionowej program dodatkowo wyznacza kąt elewacji i zmianę zysku dipola."
                                 AccessibleText="Niepewność pola jest pierwiastkiem z sumy kwadratów niepewności odbiornika, poprawki antenowej i kabla."/>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Results}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="f [MHz]" Width="0.65*" Binding="{Binding FrequencyText}"/>
        <DataGridTextColumn Header="AF H [dB/m]" Width="0.9*" Binding="{Binding HorizontalAntennaFactorText}"/>
        <DataGridTextColumn Header="α V [°]" Width="0.75*" Binding="{Binding VerticalAngleText}"/>
        <DataGridTextColumn Header="korekta V [dB]" Width="1.0*" Binding="{Binding VerticalCorrectionText}"/>
        <DataGridTextColumn Header="AF V corr [dB/m]" Width="1.1*" Binding="{Binding VerticalCorrectedAntennaFactorText}"/>
        <DataGridTextColumn Header="E H [dBµV/m]" Width="1.05*" Binding="{Binding HorizontalFieldText}"/>
        <DataGridTextColumn Header="E V [dBµV/m]" Width="1.05*" Binding="{Binding VerticalFieldText}"/>
        <DataGridTextColumn Header="maks. pol." Width="0.9*" Binding="{Binding MaximumPolarizationText}"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
