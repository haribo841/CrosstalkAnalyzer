<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.Step3View"
             x:DataType="vm:Step3ViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="14">
    <StackPanel Spacing="4">
      <TextBlock Text="Niepewność analizatora"
                 FontSize="20"
                 FontWeight="SemiBold"/>
      <TextBlock Text="{Binding UncertaintyDescription}"
                 Foreground="#59677C"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <Border Grid.Row="1"
            Background="#172B4D"
            CornerRadius="10"
            Padding="18,14">
      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="28">
        <StackPanel Spacing="4">
          <TextBlock Text="BŁĄD BEZWZGLĘDNY"
                     Foreground="#8FB3FF"
                     FontSize="11"
                     FontWeight="Bold"/>
          <TextBlock Text="ΔZ = |Z|ₗᵢₙ · (10 ^ (U_D / 20) − 1)"
                     Foreground="White"
                     FontFamily="Consolas"
                     FontSize="18"/>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Spacing="4">
          <TextBlock Text="PRZEDZIAŁ WYNIKU"
                     Foreground="#8FB3FF"
                     FontSize="11"
                     FontWeight="Bold"/>
          <TextBlock Text="⟨ max(0, |Z|ₗᵢₙ − ΔZ); |Z|ₗᵢₙ + ΔZ ⟩"
                     Foreground="White"
                     FontFamily="Consolas"
                     FontSize="18"/>
        </StackPanel>
      </Grid>
    </Border>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Results}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="f [GHz]"
                            Width="0.7*"
                            Binding="{Binding FrequencyText}"/>
        <DataGridTextColumn Header="U_D [dB]"
                            Width="0.8*"
                            Binding="{Binding UncertaintyText}"/>
        <DataGridTextColumn Header="ΔZ NEXT"
                            Width="1.1*"
                            Binding="{Binding NearDeltaText}"/>
        <DataGridTextColumn Header="Przedział NEXT"
                            Width="2.2*"
                            Binding="{Binding NearIntervalText}"/>
        <DataGridTextColumn Header="ΔZ FEXT"
                            Width="1.1*"
                            Binding="{Binding FarDeltaText}"/>
        <DataGridTextColumn Header="Przedział FEXT"
                            Width="2.2*"
                            Binding="{Binding FarIntervalText}"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
