<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CrosstalkAnalyzer.Controls"
             xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
             x:Class="CrosstalkAnalyzer.Views.Step3View"
             x:DataType="vm:Step3ViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="14">
    <StackPanel Spacing="4">
      <TextBlock Text="Niepewność analizatora"
                 FontSize="20"
                 FontWeight="SemiBold"/>
      <TextBlock Text="{Binding UncertaintyDescription}"
                 Foreground="#59677C"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">
      <controls:MathFormulaControl Caption="BŁĄD BEZWZGLĘDNY"
                                   Latex="\Delta Z=|Z|_{\mathrm{lin}}\left(10^{\frac{U_D}{20}}-1\right)"
                                   Description="UD - dokładność amplitudowa analizatora dla danego poziomu i częstotliwości."
                                   AccessibleText="Delta Z jest iloczynem wartości liniowej oraz dziesięć do potęgi UD przez dwadzieścia, pomniejszonego o jeden."/>
      <controls:MathFormulaControl Grid.Column="1"
                                   Caption="PRZEDZIAŁ WYNIKU"
                                   Latex="\left[\max\left(0,|Z|_{\mathrm{lin}}-\Delta Z\right),\ |Z|_{\mathrm{lin}}+\Delta Z\right]"
                                   Description="Granica dolna nie może być mniejsza od zera, ponieważ moduł jest nieujemny."
                                   AccessibleText="Przedział od maksimum z zera i wartości liniowej minus delta Z do wartości liniowej plus delta Z."/>
    </Grid>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Results}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="f [GHz]"
                            Width="0.7*"
                            Binding="{Binding FrequencyText}"/>
        <DataGridTextColumn Header="U NEXT [dB]"
                            Width="0.8*"
                            Binding="{Binding NearUncertaintyText}"/>
        <DataGridTextColumn Header="ΔZ NEXT"
                            Width="1.1*"
                            Binding="{Binding NearDeltaText}"/>
        <DataGridTextColumn Header="Przedział NEXT"
                            Width="2.2*"
                            Binding="{Binding NearIntervalText}"/>
        <DataGridTextColumn Header="ΔZ FEXT"
                            Width="1.1*"
                            Binding="{Binding FarDeltaText}"/>
        <DataGridTextColumn Header="U FEXT [dB]"
                            Width="0.8*"
                            Binding="{Binding FarUncertaintyText}"/>
        <DataGridTextColumn Header="Przedział FEXT"
                            Width="2.2*"
                            Binding="{Binding FarIntervalText}"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
