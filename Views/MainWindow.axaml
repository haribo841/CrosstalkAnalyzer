<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
        x:Class="CrosstalkAnalyzer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="EMC Lab Assistant"
        Width="1220"
        Height="800"
        MinWidth="960"
        MinHeight="680"
        Background="#F4F6FA"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#172B4D"
            Padding="26,18">
      <Grid ColumnDefinitions="*,370">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding ApplicationTitle}"
                     Foreground="#8FB3FF"
                     FontSize="11"
                     FontWeight="SemiBold"
                     LetterSpacing="1.5"/>
          <TextBlock Text="{Binding StepTitle}"
                     Foreground="White"
                     FontSize="25"
                     FontWeight="SemiBold"/>
          <TextBlock Text="{Binding ScenarioName}"
                     Foreground="#D9E4F7"
                     FontSize="13"
                     FontWeight="SemiBold"/>
          <TextBlock Text="{Binding StepDescription}"
                     Foreground="#AFC0DA"
                     FontSize="12"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding IsAnalysisActive}">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Postęp badania" Foreground="#C9D5EA"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding StepCounter}"
                       Foreground="White"
                       FontWeight="SemiBold"/>
          </Grid>
          <ProgressBar Minimum="0"
                       Maximum="4"
                       Value="{Binding ProgressValue}"
                       Height="8"
                       Foreground="#4F8CFF"
                       Background="#30486F"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="card"
            Margin="24,20,24,14"
            Padding="22">
      <ContentControl Content="{Binding CurrentStepViewModel}"/>
    </Border>

    <Border Grid.Row="2"
            Background="White"
            BorderBrush="#DDE3EC"
            BorderThickness="0,1,0,0"
            Padding="24,14">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto"
            IsVisible="{Binding IsAnalysisActive}">
        <Button Content="← Wstecz"
                Classes="secondary"
                Command="{Binding PreviousStepCommand}"/>
        <Button Grid.Column="1"
                Margin="10,0,0,0"
                Content="Zmień scenariusz"
                Classes="secondary"
                Command="{Binding ChangeScenarioCommand}"/>

        <TextBlock x:Name="ExportStatusText"
                   Grid.Column="2"
                   Margin="18,0"
                   VerticalAlignment="Center"
                   Foreground="#28734A"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="10">
          <Button Content="Nowe badanie"
                  Classes="secondary"
                  IsVisible="{Binding IsFinalStep}"
                  Command="{Binding NewAnalysisCommand}"/>
          <Button Content="Eksportuj CSV"
                  Classes="primary"
                  IsVisible="{Binding IsFinalStep}"
                  Click="ExportCsv_Click"/>
          <Button Content="Dalej →"
                  Classes="primary"
                  IsVisible="{Binding IsNotFinalStep}"
                  Command="{Binding NextStepCommand}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
