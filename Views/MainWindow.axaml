<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrosstalkAnalyzer.ViewModels"
        x:Class="CrosstalkAnalyzer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="EMC Lab Assistant"
        Width="1220"
        Height="800"
        MinWidth="820"
        MinHeight="600"
        Background="#F4F6FA"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#172B4D"
            Padding="26,18">
      <Grid ColumnDefinitions="2*,*"
            ColumnSpacing="24">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding ApplicationTitle}"
                     Foreground="#8FB3FF"
                     FontSize="11"
                     FontWeight="SemiBold"
                     LetterSpacing="1.5"/>
          <TextBlock Text="{Binding StepTitle}"
                     Foreground="White"
                     FontSize="25"
                     FontWeight="SemiBold"/>
          <TextBlock Text="{Binding ScenarioName}"
                     Foreground="#D9E4F7"
                     FontSize="13"
                     FontWeight="SemiBold"/>
          <TextBlock Text="{Binding StepDescription}"
                     Foreground="#AFC0DA"
                     FontSize="12"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding IsWizardScenario}">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Postęp badania" Foreground="#C9D5EA"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding StepCounter}"
                       Foreground="White"
                       FontWeight="SemiBold"/>
          </Grid>
          <ProgressBar Minimum="0"
                       Maximum="4"
                       Value="{Binding ProgressValue}"
                       Height="8"
                       Foreground="#4F8CFF"
                       Background="#30486F"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border x:Name="MainContentBorder"
            Grid.Row="1"
            Classes="card"
            Margin="24,20,24,14"
            Padding="22"
            ClipToBounds="True">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <ContentControl Content="{Binding CurrentStepViewModel}"/>
      </ScrollViewer>
    </Border>

    <Border x:Name="FooterBorder"
            Grid.Row="2"
            Background="White"
            BorderBrush="#DDE3EC"
            BorderThickness="0,1,0,0"
            Padding="24,14">
      <Grid RowDefinitions="Auto,Auto"
            RowSpacing="8"
            IsVisible="{Binding IsAnalysisActive}">
        <TextBlock x:Name="ExportStatusText"
                   Grid.Row="0"
                   VerticalAlignment="Center"
                   Foreground="#28734A"
                   TextWrapping="Wrap"/>
        <Grid x:Name="FooterActionsGrid"
              Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
          <WrapPanel Orientation="Horizontal">
            <Button Content="← Wstecz"
                    Classes="secondary"
                    Margin="0,0,10,0"
                    IsVisible="{Binding IsWizardScenario}"
                    Command="{Binding PreviousStepCommand}"/>
            <Button Content="Zmień scenariusz"
                    Classes="secondary"
                    Command="{Binding ChangeScenarioCommand}"/>
          </WrapPanel>
          <WrapPanel Grid.Column="1" Orientation="Horizontal">
            <Button Content="Nowe badanie"
                    Classes="secondary"
                    Margin="0,0,10,0"
                    IsVisible="{Binding IsFinalStep}"
                    Command="{Binding NewAnalysisCommand}"/>
            <Button Content="Eksportuj CSV"
                    Classes="primary"
                    Margin="0,0,10,0"
                    IsVisible="{Binding IsFinalStep}"
                    Click="ExportCsv_Click"/>
            <Button Content="Eksportuj DOCX"
                    Classes="primary"
                    IsVisible="{Binding IsFinalStep}"
                    Click="ExportDocx_Click"/>
            <Button Content="Dalej →"
                    Classes="primary"
                    IsVisible="{Binding IsNotFinalStep}"
                    Command="{Binding NextStepCommand}"/>
          </WrapPanel>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
